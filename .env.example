# PostgreSQL
POSTGRES_USER=wb
POSTGRES_PASSWORD=wb_secret
POSTGRES_DB=wb_saas

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=wb_analytics

# Redis
REDIS_URL=redis://localhost:6379/0

# WB API (получить в личном кабинете продавца)
WB_API_KEY=your_wildberries_api_key_here

# Прокси для парсера (формат: http://user:pass@host:port)
PROXY_LIST=http://proxy1:port,http://proxy2:port

# Безопасность
SECRET_KEY=change_me_in_production
